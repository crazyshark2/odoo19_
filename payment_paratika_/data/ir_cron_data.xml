<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Cron job for syncing installment rates (optional) -->
    <record id="ir_cron_paratika_sync_rates" model="ir.cron">
        <field name="name">Paratika: Taksit Oranlarını Senkronize Et</field>
        <field name="model_id" ref="model_payment_provider"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_paratika_rates()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="False"/>
        <field name="doall" eval="False"/>
    </record>
</odoo>