<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend payment provider form for Paratika settings -->
    <record id="payment_provider_form_view_paratika" model="ir.ui.view">
        <field name="name">payment.provider.form.paratika</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <!-- Paratika Credentials Tab -->
                <page string="Paratika Ayarları" name="paratika_credentials"
                      attrs="{'invisible': [('code', '!=', 'paratika')]}">
                    
                    <group string="API Kimlik Bilgileri">
                        <field name="paratika_merchant_user"/>
                        <field name="paratika_merchant_password" password="True"/>
                        <field name="paratika_merchant_id"/>
                        <field name="paratika_secret_key" password="True"/>
                    </group>
                    
                    <group string="Entegrasyon Ayarları">
                        <field name="paratika_integration_mode"/>
                        <field name="paratika_api_url" attrs="{'invisible': [('paratika_test_mode', '=', True)]}"/>
                        <field name="paratika_test_mode"/>
                    </group>
                    
                    <div class="alert alert-info mt-3" role="alert">
                        <h5>📋 API Bilgileri Nereden Alınır?</h5>
                        <ol class="mb-0">
                            <li>https://entegrasyon.paratika.com.tr adresine giriş yapın</li>
                            <li>Merchant Panel → API Yönetimi bölümüne gidin</li>
                            <li>API kullanıcı adı, şifre ve Secret Key bilgilerinizi kopyalayın</li>
                            <li>Test modunda entegrasyon.paratika.com.tr, production'da entegrasyon.paratika.com.tr kullanın</li>
                        </ol>
                    </div>
                </page>
                
                <!-- Category-Based Payment Tab (NEW) -->
                <page string="Kategori Ayarları" name="paratika_categories"
                      attrs="{'invisible': [('code', '!=', 'paratika')]}">
                    
                    <group string="Kategori Kısıtlamaları">
                        <field name="paratika_category_restriction"/>
                        
                        <field name="paratika_allowed_category_ids" 
                               attrs="{'invisible': [('paratika_category_restriction', '!=', 'allow')], 
                                       'required': [('paratika_category_restriction', '=', 'allow')]}"
                               widget="many2many_tags"
                               placeholder="İzin verilen kategorileri seçin..."/>
                        
                        <field name="paratika_denied_category_ids" 
                               attrs="{'invisible': [('paratika_category_restriction', '!=', 'deny')], 
                                       'required': [('paratika_category_restriction', '=', 'deny')]}"
                               widget="many2many_tags"
                               placeholder="Hariç tutulacak kategorileri seçin..."/>
                    </group>
                    
                    <separator string="Kategori Bazlı Taksit Kuralları"/>
                    
                    <group>
                        <field name="paratika_enable_category_installments"/>
                    </group>
                    
                    <field name="paratika_category_installment_ids" 
                           attrs="{'invisible': [('paratika_enable_category_installments', '=', False)]}"
                           context="{'default_provider_id': active_id}"
                           mode="tree,form">
                        <tree editable="bottom">
                            <field name="category_id"/>
                            <field name="allowed_installments"/>
                            <field name="default_installment"/>
                            <field name="commission_rate"/>
                        </tree>
                        <form>
                            <sheet>
                                <group>
                                    <field name="category_id"/>
                                    <field name="sequence"/>
                                    <field name="allowed_installments"/>
                                    <field name="default_installment"/>
                                    <field name="commission_rate"/>
                                    <field name="bank_specific_rules"/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                    
                    <div class="alert alert-warning mt-3" role="alert">
                        <h5>🎯 Kategori Bazlı Akış Nasıl Çalışır?</h5>
                        <ol>
                            <li><strong>İzin Ver:</strong> Sadece seçilen kategorilerde bu ödeme yöntemi görünür</li>
                            <li><strong>Hariç Tut:</strong> Seçilen kategoriler dışında görünür</li>
                            <li><strong>Taksit Kuralları:</strong> Her kategori için farklı taksit/komisyon tanımlayın</li>
                        </ol>
                        <p class="mb-0"><em>Örnek: "Elektronik" kategorisi için max 3 taksit, "Ev &amp; Yaşam" için 12 taksit</em></p>
                    </div>
                </page>
            </notebook>
        </field>
    </record>
    
    <!-- Provider tree view extension -->
    <record id="payment_provider_tree_view_paratika" model="ir.ui.view">
        <field name="name">payment.provider.tree.paratika</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_tree"/>
        <field name="arch" type="xml">
            <field name="code" position="after">
                <field name="paratika_integration_mode" attrs="{'invisible': [('code', '!=', 'paratika')]}"/>
                <field name="paratika_test_mode" attrs="{'invisible': [('code', '!=', 'paratika')]}"/>
            </field>
        </field>
    </record>
</odoo>