<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- =================================================================== -->
    <!-- PAYMENT TRANSACTION TREE VIEW -->
    <!-- =================================================================== -->
    <record id="payment_transaction_tree_view_paratika" model="ir.ui.view">
        <field name="name">payment.transaction.tree.paratika</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_tree"/>
        <field name="arch" type="xml">
            <field name="provider_id" position="after">
                <!-- Paratika Specific Fields -->
                <field name="paratika_pg_tras_id" 
                       attrs="{'invisible': [('provider_id.code', '!=', 'paratika')]}"
                       optional="show"/>
                <field name="paratika_installment_count" 
                       attrs="{'invisible': [('provider_id.code', '!=', 'paratika')]}"
                       optional="show"/>
                <field name="paratika_card_mask" 
                       attrs="{'invisible': [('provider_id.code', '!=', 'paratika')]}"
                       optional="show"/>
            </field>
            
            <field name="state" position="attributes">
                <attribute name="widget">badge</attribute>
                <attribute name="decoration-success">state == 'done'</attribute>
                <attribute name="decoration-warning">state == 'pending'</attribute>
                <attribute name="decoration-danger">state == 'error'</attribute>
                <attribute name="decoration-info">state == 'authorized'</attribute>
            </field>
        </field>
    </record>
    
    <!-- =================================================================== -->
    <!-- PAYMENT TRANSACTION FORM VIEW -->
    <!-- =================================================================== -->
    <record id="payment_transaction_form_view_paratika" model="ir.ui.view">
        <field name="name">payment.transaction.form.paratika</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form"/>
        <field name="arch" type="xml">
            <sheet position="inside">
                <!-- Paratika Tab -->
                <notebook position="inside">
                    <page string="Paratika Detayları" 
                          name="paratika_details"
                          attrs="{'invisible': [('provider_id.code', '!=', 'paratika')]}">
                        
                        <!-- Transaction References -->
                        <group string="İşlem Referansları" col="2">
                            <field name="paratika_pg_tras_id" readonly="1"/>
                            <field name="paratika_pg_order_id" readonly="1"/>
                            <field name="paratika_auth_code" readonly="1"/>
                            <field name="paratika_host_ref_num" readonly="1"/>
                        </group>
                        
                        <!-- Card Information -->
                        <group string="Kart Bilgileri" col="2">
                            <field name="paratika_card_mask" readonly="1"/>
                            <field name="paratika_card_type" readonly="1"/>
                            <field name="paratika_installment_count" readonly="1"/>
                            <field name="paratika_selected_bank" readonly="1"/>
                        </group>
                        
                        <!-- Category Information -->
                        <group string="Kategori Bilgisi" col="1">
                            <field name="paratika_category_ids" 
                                   widget="many2many_tags" 
                                   readonly="1"
                                   options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        
                        <!-- Callback Data (JSON) -->
                        <group string="Callback Verisi" col="1">
                            <field name="paratika_callback_date" readonly="1"/>
                            <field name="paratika_callback_data" 
                                   widget="json" 
                                   readonly="1"
                                   options="{'mode': 'tree'}"/>
                        </group>
                        
                        <!-- Actions -->
                        <group string="İşlem Aksiyonları" col="1">
                            <button name="%(action_payment_transaction_refund)d" 
                                    string="İade Yap" 
                                    type="action"
                                    class="btn-warning"
                                    attrs="{'invisible': ['|', ('state', '!=', 'done'), ('provider_id.code', '!=', 'paratika')]}"
                                    icon="fa-undo"/>
                            <button name="action_capture" 
                                    string="Otorizasyonu Tamamla" 
                                    type="object"
                                    class="btn-success"
                                    attrs="{'invisible': ['|', ('state', '!=', 'authorized'), ('provider_id.code', '!=', 'paratika')]}"
                                    icon="fa-check"/>
                            <button name="action_void" 
                                    string="Otorizasyonu İptal Et" 
                                    type="object"
                                    class="btn-danger"
                                    attrs="{'invisible': ['|', ('state', '!=', 'authorized'), ('provider_id.code', '!=', 'paratika')]}"
                                    icon="fa-times"/>
                        </group>
                    </page>
                </notebook>
            </sheet>
            
            <!-- Header Status Badge -->
            <header position="inside">
                <field name="provider_id" invisible="1"/>
                <button name="action_view_paratika_transaction" 
                        string="Paratika'da Görüntüle" 
                        type="object"
                        class="btn-secondary"
                        attrs="{'invisible': ['|', ('provider_id.code', '!=', 'paratika'), ('paratika_pg_tras_id', '=', False)]}"
                        icon="fa-external-link"/>
            </header>
        </field>
    </record>
    
    <!-- =================================================================== -->
    <!-- PAYMENT TRANSACTION SEARCH VIEW -->
    <!-- =================================================================== -->
    <record id="payment_transaction_search_view_paratika" model="ir.ui.view">
        <field name="name">payment.transaction.search.paratika</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_search"/>
        <field name="arch" type="xml">
            <filter name="provider" position="after">
                <!-- Paratika Filters -->
                <filter string="Paratika" 
                        name="provider_paratika" 
                        domain="[('provider_id.code', '=', 'paratika')]"
                        help="Paratika ile yapılan işlemler"/>
            </filter>
            
            <group position="inside">
                <!-- Paratika Filter Group -->
                <filter string="Paratika" name="paratika_group" domain="[('provider_id.code', '=', 'paratika')]">
                    <filter string="PG Transaction ID" 
                            name="paratika_pg_tras_id" 
                            domain="[('paratika_pg_tras_id', 'ilike', self)]"/>
                    <filter string="Kart Maskesi" 
                            name="paratika_card_mask" 
                            domain="[('paratika_card_mask', 'ilike', self)]"/>
                    <filter string="Taksit Sayısı" 
                            name="paratika_installment" 
                            domain="[('paratika_installment_count', '=', self)]"/>
                    <separator/>
                    <filter string="Elektronik Kategorisi" 
                            name="cat_electronics" 
                            domain="[('paratika_category_ids.name', 'ilike', 'elektronik')]"/>
                    <filter string="Ev &amp; Yaşam" 
                            name="cat_home" 
                            domain="[('paratika_category_ids.name', 'ilike', 'ev')]"/>
                </filter>
            </group>
        </field>
    </record>
    
    <!-- =================================================================== -->
    <!-- PAYMENT TRANSACTION PIVOT/GRAPH VIEWS -->
    <!-- =================================================================== -->
    <record id="payment_transaction_pivot_view_paratika" model="ir.ui.view">
        <field name="name">payment.transaction.pivot.paratika</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_pivot"/>
        <field name="arch" type="xml">
            <pivot position="inside">
                <field name="provider_id" type="row" 
                       attrs="{'invisible': [('provider_id.code', '!=', 'paratika')]}"/>
                <field name="paratika_installment_count" type="row" optional="show"/>
                <field name="paratika_category_ids" type="row" optional="hide"/>
            </pivot>
        </field>
    </record>
    
    <!-- =================================================================== -->
    <!-- PAYMENT TRANSACTION KANBAN VIEW -->
    <!-- =================================================================== -->
    <record id="payment_transaction_kanban_view_paratika" model="ir.ui.view">
        <field name="name">payment.transaction.kanban.paratika</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_kanban"/>
        <field name="arch" type="xml">
            <kanban position="inside">
                <!-- Paratika Specific Fields in Kanban -->
                <field name="provider_id"/>
                <field name="paratika_pg_tras_id"/>
                <field name="paratika_card_mask"/>
                <field name="paratika_installment_count"/>
                
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="reference"/>
                                    </strong>
                                </div>
                                <!-- Provider Badge -->
                                <t t-if="record.provider_id.raw_value == 'paratika'">
                                    <span class="badge bg-primary">Paratika</span>
                                </t>
                            </div>
                            
                            <div class="o_kanban_record_body">
                                <!-- Amount -->
                                <div>
                                    <strong><field name="amount" widget="monetary"/></strong>
                                    <field name="currency_id" invisible="1"/>
                                </div>
                                
                                <!-- Paratika Details -->
                                <t t-if="record.provider_id.raw_value == 'paratika'">
                                    <div class="text-muted small mt-1">
                                        <t t-if="record.paratika_card_mask.raw_value">
                                            <i class="fa fa-credit-card me-1"/>
                                            <field name="paratika_card_mask"/>
                                        </t>
                                        <t t-if="record.paratika_installment_count.raw_value &gt; 1">
                                            • <field name="paratika_installment_count"/> Taksit
                                        </t>
                                    </div>
                                    
                                    <!-- Category Tags -->
                                    <t t-if="record.paratika_category_ids.raw_value.length">
                                        <div class="mt-1">
                                            <t t-foreach="record.paratika_category_ids.raw_value.slice(0, 2)" t-as="cat">
                                                <span class="badge bg-light text-dark border me-1" t-esc="cat"/>
                                            </t>
                                            <t t-if="record.paratika_category_ids.raw_value.length &gt; 2">
                                                <span class="badge bg-light text-dark border">+<t t-esc="record.paratika_category_ids.raw_value.length - 2"/></span>
                                            </t>
                                        </div>
                                    </t>
                                </t>
                            </div>
                            
                            <div class="o_kanban_record_bottom">
                                <!-- Status Badge -->
                                <field name="state" widget="badge"/>
                                
                                <!-- Quick Actions -->
                                <div class="oe_kanban_bottom_right">
                                    <t t-if="record.provider_id.raw_value == 'paratika' and record.paratika_pg_tras_id.raw_value">
                                        <a type="object" 
                                           name="action_view_paratika_transaction" 
                                           class="oe_kanban_action"
                                           title="Paratika'da Aç">
                                            <i class="fa fa-external-link"/>
                                        </a>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- =================================================================== -->
    <!-- PARATIKA TRANSACTION DETAIL ACTION -->
    <!-- =================================================================== -->
    <record id="action_view_paratika_transaction" model="ir.actions.server">
        <field name="name">Paratika'da İşlemi Görüntüle</field>
        <field name="model_id" ref="payment.model_payment_transaction"/>
        <field name="binding_model_id" ref="payment.model_payment_transaction"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
            if record.provider_id.code == 'paratika' and record.paratika_pg_tras_id:
                base_url = record.provider_id._get_paratika_base_url().replace('/api/v2', '')
                action = {
                    'type': 'ir.actions.act_url',
                    'url': f"{base_url}/merchant/transaction/{record.paratika_pg_tras_id}",
                    'target': 'new',
                }
            else:
                raise UserError("Bu işlem Paratika ile ilişkilendirilmemiş veya PG Transaction ID bulunamadı.")
        </field>
    </record>
    
</odoo>